{
  "packageManager": "bun@1.3.10",
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^22.19.15",
    "browserslist": "^4.28.1",
    "caniuse-lite": "^1.0.30001777",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "prettier-plugin-go-template": "^0.0.15",
    "tailwindcss": "^4.2.1"
  },
  "scripts": {
    "dev": "bun --bun --parallel \"bun run server\" \"bun run watch\"",
    "server": "hugo server -D --navigateToChanged",
    "watch": "tailwindcss -i ./assets/css/input.css -o ./assets/css/custom.css --watch",
    "build": "tailwindcss -i ./assets/css/input.css -o ./assets/css/custom.css",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{html,json,yaml}": "prettier --write",
    "*.{jpeg,jpg,png,gif}": "mogrify -strip"
  },
  "browserslist": [
    "defaults and fully supports es6-module",
    "maintained node versions"
  ]
}
